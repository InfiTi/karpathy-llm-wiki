{
  "name": "karpathy-llm-wiki",
  "version": "0.1.0",
  "description": "Local LLM Wiki system based on Karpathy's concept - Ingest, Query, Lint",
  "main": "main/index.js",
  "scripts": {
    "dev": "npm run build:core && npm run build:main && concurrently -k \"npm run dev:renderer\" \"wait-on http://localhost:3001 && npm run dev:electron\"",
    "build:core": "node scripts/build-core.js",
    "build:main": "tsc --project tsconfig.main.json",
    "dev:renderer": "vite --port 3001",
    "dev:electron": "electron .",
    "build": "npm run build:core && npm run build:main && vite build && electron-builder",
    "test": "jest",
    "lint": "eslint src --ext .js,.jsx,.ts,.tsx"
  },
  "keywords": [
    "llm",
    "wiki",
    "knowledge-base",
    "obsidian",
    "ollama"
  ],
  "author": "Karpathy LLM Wiki",
  "license": "MIT",
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/node": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-typescript": "^7.28.5",
    "@electron-forge/cli": "^7.4.0",
    "@electron-forge/maker-squirrel": "^7.4.0",
    "@electron-forge/maker-zip": "^7.4.0",
    "@electron-forge/plugin-vite": "^7.4.0",
    "@types/electron": "^1.4.38",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.0.1",
    "electron": "^32.0.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.0.0",
    "jest": "^29.7.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2",
    "vite": "^5.4.0",
    "wait-on": "^8.0.0"
  },
  "dependencies": {
    "@types/cheerio": "^0.22.35",
    "axios": "^1.7.7",
    "cheerio": "^1.2.0",
    "chokidar": "^4.0.1",
    "electron-store": "^10.0.0",
    "fs-extra": "^11.2.0",
    "glob": "^11.0.0",
    "gray-matter": "^4.0.3",
    "marked": "^14.1.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "react-router-dom": "^6.26.2",
    "zustand": "^5.0.0"
  },
  "build": {
    "appId": "com.karpathy.llm-wiki",
    "productName": "Karpathy LLM Wiki",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "main/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
