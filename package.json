{
  "name": "karpathy-llm-wiki",
  "version": "0.1.0",
  "description": "Local LLM Wiki system based on Karpathy's concept - Ingest, Query, Lint",
  "main": "src/main/index.js",
  "scripts": {
    "dev": "npm run build:core && concurrently -k \"npm run dev:renderer\" \"wait-on http://localhost:3000 && npm run dev:electron\"",
    "build:core": "node scripts/build-core.js",
    "dev:renderer": "vite --port 3000",
    "dev:electron": "electron .",
    "build": "npm run build:core && vite build && electron-builder",
    "test": "jest",
    "lint": "eslint src --ext .js,.jsx,.ts,.tsx"
  },
  "keywords": [
    "llm",
    "wiki",
    "knowledge-base",
    "obsidian",
    "ollama"
  ],
  "author": "Karpathy LLM Wiki",
  "license": "MIT",
  "devDependencies": {
    "@electron-forge/cli": "^7.4.0",
    "@electron-forge/maker-squirrel": "^7.4.0",
    "@electron-forge/maker-zip": "^7.4.0",
    "@electron-forge/plugin-vite": "^7.4.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.0.1",
    "electron": "^32.0.0",
    "eslint": "^9.0.0",
    "jest": "^29.7.0",
    "vite": "^5.4.0",
    "wait-on": "^8.0.0"
  },
  "dependencies": {
    "axios": "^1.7.7",
    "electron-store": "^10.0.0",
    "fs-extra": "^11.2.0",
    "gray-matter": "^4.0.3",
    "marked": "^14.1.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "react-markdown": "^9.0.1",
    "zustand": "^5.0.0",
    "chokidar": "^4.0.1",
    "glob": "^11.0.0"
  }
}